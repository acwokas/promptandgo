---
const cols = [
  { title: "Product", links: [
    { href: "/library", label: "Browse Prompts" },
    { href: "/packs", label: "Power Packs" },
    { href: "/optimize", label: "Optimizer" },
    { href: "/ai/studio", label: "Prompt Studio" },
    { href: "/ai/assistant", label: "AI Assistant" },
    { href: "/pricing", label: "Pricing" },
  ]},
  { title: "By Market", links: [
    { href: "/ja", label: "Japan / 日本" },
    { href: "/ko", label: "Korea / 한국" },
    { href: "/zh", label: "China / 中国" },
    { href: "/th", label: "Thailand / ไทย" },
    { href: "/vi", label: "Vietnam / Việt Nam" },
    { href: "/market-insights", label: "Market Insights" },
  ]},
  { title: "Resources", links: [
    { href: "/tips", label: "Guides & Tips" },
    { href: "/glossary", label: "AI Glossary" },
    { href: "/help", label: "Help Center" },
    { href: "/api-docs", label: "API Docs" },
    { href: "/changelog", label: "Changelog" },
    { href: "/blog", label: "Blog" },
  ]},
  { title: "Company", links: [
    { href: "/about", label: "About" },
    { href: "/contact", label: "Contact" },
    { href: "/careers", label: "Careers" },
    { href: "/partners", label: "Partners" },
    { href: "/enterprise", label: "Enterprise" },
    { href: "/status", label: "Status" },
  ]},
];
const year = new Date().getFullYear();
---
<footer class="relative border-t border-border/50 mt-24 bg-secondary/30">
  <!-- gradient hairline at top -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-brand opacity-50"></div>

  <div class="container max-w-7xl py-16">
    <div class="grid lg:grid-cols-[1.5fr_4fr] gap-12 mb-14">
      <!-- Brand column -->
      <div>
        <a href="/" aria-label="PromptAndGo home" class="inline-block">
          <img src="/brand/logo.png" alt="PromptAndGo.ai" width="200" height="42" class="h-9 w-auto" />
        </a>
        <p class="mt-4 text-sm text-muted-foreground max-w-xs leading-relaxed">
          AI prompts built for Asia. Culturally aware, platform-optimised, and ready to ship work.
        </p>
        <div class="mt-5 flex items-center gap-3">
          <a href="https://twitter.com/promptandgoai" aria-label="Twitter" class="w-9 h-9 rounded-lg border border-border/60 grid place-items-center text-muted-foreground hover:text-primary hover:border-primary/40 transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://linkedin.com/company/promptandgoai" aria-label="LinkedIn" class="w-9 h-9 rounded-lg border border-border/60 grid place-items-center text-muted-foreground hover:text-primary hover:border-primary/40 transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="/contact" aria-label="Contact" class="w-9 h-9 rounded-lg border border-border/60 grid place-items-center text-muted-foreground hover:text-primary hover:border-primary/40 transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        </div>
      </div>

      <!-- Link columns -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {cols.map(c => (
          <div>
            <h3 class="font-semibold text-sm mb-4">{c.title}</h3>
            <ul class="space-y-2.5 text-sm text-muted-foreground">
              {c.links.map(l => (
                <li><a href={l.href} class="hover:text-primary transition-colors">{l.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-border/50 pt-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-xs text-muted-foreground">
      <div>© {year} PromptAndGo.ai · Built for Asia.</div>
      <div class="flex flex-wrap gap-x-5 gap-y-2">
        <a href="/terms" class="hover:text-primary">Terms</a>
        <a href="/privacy" class="hover:text-primary">Privacy</a>
        <a href="/cookies" class="hover:text-primary">Cookies</a>
        <a href="/accessibility" class="hover:text-primary">Accessibility</a>
        <a href="/sitemap" class="hover:text-primary">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
