---
const navLinks = [
  { href: "/library", label: "Browse Prompts" },
  { href: "/packs", label: "Power Packs" },
  { href: "/pricing", label: "Pricing" },
  { href: "/about", label: "About" },
  { href: "/blog", label: "Blog" },
];
const cur = Astro.url.pathname;
---
<header class="sticky top-0 z-40 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/80">
  <div class="container flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 font-bold tracking-tight" aria-label="PromptAndGo home">
      <span class="text-2xl">prompt<span class="text-gradient-brand">and</span>go.<span class="text-primary">ai</span></span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm font-medium" aria-label="Main">
      {navLinks.map(l => (
        <a href={l.href} class={`hover:text-primary transition-colors ${cur === l.href ? 'text-primary' : 'text-foreground/80'}`}>
          {l.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <button
        type="button"
        aria-label="Toggle theme"
        id="theme-toggle"
        class="inline-flex items-center justify-center rounded-md w-9 h-9 hover:bg-secondary"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="dark:hidden"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden dark:block"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <a href="/auth" class="hidden sm:inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-4 py-2 text-sm font-semibold hover:bg-primary/90 transition-colors">
        Sign in
      </a>
      <button id="mobile-toggle" type="button" aria-label="Open menu" class="md:hidden inline-flex items-center justify-center rounded-md w-9 h-9 hover:bg-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t border-border/40 bg-background">
    <nav class="container py-3 flex flex-col gap-2 text-sm" aria-label="Mobile">
      {navLinks.map(l => (
        <a href={l.href} class={`py-2 hover:text-primary ${cur === l.href ? 'text-primary' : ''}`}>{l.label}</a>
      ))}
      <a href="/auth" class="mt-2 inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-4 py-2 font-semibold">Sign in</a>
    </nav>
  </div>
</header>

<script is:inline>
  (function(){
    const t = document.getElementById('theme-toggle');
    if (t) t.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch(e) {}
    });
    const m = document.getElementById('mobile-toggle');
    const mm = document.getElementById('mobile-menu');
    if (m && mm) m.addEventListener('click', () => mm.classList.toggle('hidden'));
  })();
</script>
