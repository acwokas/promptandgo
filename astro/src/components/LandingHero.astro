---
interface Props {
  langTag: string;
  langLabel: string;
  langSub: string;
  hero: { title: string; subtitle: string; cta: string };
  features: { title: string; desc: string }[];
  examples: { input: string; output: string }[];
}
const { langTag, langLabel, langSub, hero, features, examples } = Astro.props;
---
<section class="container py-16 md:py-24" lang={langTag}>
  <div class="text-center max-w-3xl mx-auto">
    <span class="inline-flex items-center gap-2 rounded-full bg-primary/10 text-primary border border-primary/20 px-3 py-1 text-sm font-medium mb-6">
      🌏 {langLabel} · {langSub}
    </span>
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight leading-tight">{hero.title}</h1>
    <p class="mt-5 text-lg md:text-xl text-muted-foreground">{hero.subtitle}</p>
    <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/optimize" class="inline-flex items-center justify-center rounded-lg bg-gradient-primary text-primary-foreground px-8 py-4 font-semibold shadow-glow">{hero.cta}</a>
      <a href="/library" class="inline-flex items-center justify-center rounded-lg border border-border px-8 py-4 font-semibold">Browse prompts →</a>
    </div>
  </div>
</section>

<section class="container py-12">
  <div class="grid md:grid-cols-3 gap-5">
    {features.map(f => (
      <div class="rounded-2xl bg-card border border-border/60 p-6">
        <h3 class="text-lg font-semibold">{f.title}</h3>
        <p class="mt-2 text-sm text-muted-foreground">{f.desc}</p>
      </div>
    ))}
  </div>
</section>

<section class="container py-12">
  <h2 class="text-2xl md:text-3xl font-bold mb-6">Examples</h2>
  <div class="space-y-4">
    {examples.map(ex => (
      <div class="rounded-xl border border-border/60 bg-card p-5">
        <div class="text-xs font-semibold uppercase text-muted-foreground mb-1">Prompt</div>
        <div lang={langTag} class="font-medium">{ex.input}</div>
        <div class="mt-3 text-xs font-semibold uppercase text-muted-foreground mb-1">Output (excerpt)</div>
        <div lang={langTag} class="text-sm text-muted-foreground">{ex.output}</div>
      </div>
    ))}
  </div>
</section>
