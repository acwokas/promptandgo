---
interface Props {
  market: string;
  flag: string;
  intro: string;
  stats: { label: string; value: string }[];
  sections: { heading: string; body: string[] }[];
}
const { market, flag, intro, stats, sections } = Astro.props;
---
<section class="relative overflow-hidden">
  <div class="brand-orb w-[400px] h-[400px] -top-20 -right-20" style="background: hsl(var(--brand-blue));"></div>
  <div class="relative container max-w-4xl pt-16 md:pt-20 pb-8">
    <a href="/market-insights" class="text-sm text-muted-foreground hover:text-primary inline-flex items-center gap-1.5">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      All market insights
    </a>
    <div class="text-6xl md:text-7xl mt-7">{flag}</div>
    <h1 class="mt-4 text-4xl md:text-6xl font-extrabold tracking-tight">
      AI Market Insights<br />
      <span class="text-gradient-brand">{market}</span>
    </h1>
    <p class="mt-6 text-lg md:text-xl text-foreground/70 leading-relaxed">{intro}</p>
  </div>
</section>

<section class="container max-w-4xl py-8">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
    {stats.map(s => (
      <div class="rounded-2xl surface-glass p-5 text-center">
        <div class="text-xl md:text-2xl font-extrabold text-gradient-brand">{s.value}</div>
        <div class="mt-1 text-xs text-muted-foreground">{s.label}</div>
      </div>
    ))}
  </div>
</section>

<section class="container max-w-3xl py-12">
  <div class="prose prose-lg dark:prose-invert max-w-none">
    {sections.map(sec => (
      <>
        <h2>{sec.heading}</h2>
        {sec.body.map(p => <p>{p}</p>)}
      </>
    ))}
  </div>
</section>

<section class="container max-w-4xl pb-20">
  <div class="relative rounded-3xl overflow-hidden">
    <div class="absolute inset-0 bg-gradient-brand-animated"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(255,255,255,0.18),transparent_50%)]"></div>
    <div class="relative p-8 md:p-12 text-center text-white">
      <h2 class="text-2xl md:text-3xl font-extrabold">Targeting {market}? Use prompts that fit.</h2>
      <p class="mt-3 text-white/90">Local language nuance, cultural context, regulatory awareness — built in.</p>
      <a href="/library" class="mt-6 inline-flex items-center justify-center rounded-xl bg-white text-primary px-6 h-11 font-semibold hover:bg-white/95 transition-colors">
        Browse {market}-relevant prompts →
      </a>
    </div>
  </div>
</section>
