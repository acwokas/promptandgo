---
import Layout from "@astro/layouts/Layout.astro";
import StaticHero from "@astro/components/StaticHero.astro";
---
<Layout title="API Docs — PromptAndGo" description="Integrate PromptAndGo into your stack.">
  <StaticHero eyebrow="API" title="API documentation." subtitle="Embed PromptAndGo's library and optimiser into your own apps." />
  <section class="container max-w-3xl pb-16">
    <div class="rounded-2xl border border-border bg-card p-7">
      <h2 class="text-xl font-bold">Coming soon</h2>
      <p class="mt-2 text-foreground/75 leading-relaxed">A REST API with endpoints for: search the library, fetch a prompt, run the optimiser, log usage. Available on Pro+ plans. Drop us a note if you're building integrations and we'll prioritise features you need.</p>
      <a href="/contact?topic=api" class="mt-5 inline-flex items-center justify-center rounded-xl bg-primary text-primary-foreground px-5 h-11 font-semibold hover:bg-primary/90 transition-colors">Tell us your use case →</a>
    </div>
  </section>
</Layout>
