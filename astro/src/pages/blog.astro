---
import Layout from "@astro/layouts/Layout.astro";
---
<Layout title="Blog — PromptAndGo" description="Stories, deep dives, and product updates from the PromptAndGo team.">
  <section class="container py-16 md:py-20">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight">Blog</h1>
    <p class="mt-4 text-lg text-muted-foreground">Stories from teams shipping AI work across Asia.</p>
    <div class="mt-12 rounded-2xl border border-border/60 bg-card p-8 text-center">
      <p class="text-muted-foreground">Migrating articles to the new platform. Browse our <a class="text-primary hover:underline" href="/tips">guides &amp; tutorials</a> in the meantime.</p>
    </div>
  </section>
</Layout>
