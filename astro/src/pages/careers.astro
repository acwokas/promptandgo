---
import Layout from "@astro/layouts/Layout.astro";
import StaticHero from "@astro/components/StaticHero.astro";
---
<Layout title="Careers — PromptAndGo" description="Join the PromptAndGo team. We build AI tools for Asia.">
  <StaticHero eyebrow="Careers" title="Build AI for Asia." subtitle="We're a small, remote team across APAC. We hire when there's real work to do — keep an eye on this page or drop us a line." />
  <section class="container max-w-3xl pb-16">
    <div class="rounded-2xl border border-border bg-card p-8">
      <h2 class="text-xl font-bold mb-3">No open roles right now</h2>
      <p class="text-foreground/75 leading-relaxed">Want to be the first to know when we're hiring? Drop us your CV and a few lines about what you'd want to build with us.</p>
      <a href="/contact?topic=careers" class="mt-5 inline-flex items-center justify-center rounded-xl bg-primary text-primary-foreground px-5 h-11 font-semibold hover:bg-primary/90 transition-colors">Send us a note →</a>
    </div>
  </section>
</Layout>
