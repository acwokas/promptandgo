---
import Layout from "@astro/layouts/Layout.astro";
import StaticHero from "@astro/components/StaticHero.astro";
const features = [
  { title: "SSO + SCIM", body: "SAML and OIDC sign-on, automatic user provisioning. Available on annual contracts." },
  { title: "Brand voice presets", body: "Save your tone-of-voice and style guides; every prompt your team optimises respects them." },
  { title: "Team libraries", body: "Shared and role-restricted prompt libraries with audit trail of who used what when." },
  { title: "DPA + data residency", body: "Standard EU and APAC data processing addenda. Singapore and Tokyo regions available." },
  { title: "Usage analytics", body: "Per-team, per-platform, per-language usage and cost reporting." },
  { title: "Dedicated channel", body: "Slack Connect or shared Teams. SLA-backed response times." },
];
---
<Layout title="Enterprise — PromptAndGo" description="PromptAndGo for enterprise teams. SSO, audit logs, shared libraries, dedicated support.">
  <StaticHero eyebrow="Enterprise" title="PromptAndGo for enterprise teams." subtitle="Shared libraries, brand voice presets, SSO, audit, and dedicated support — for organisations shipping AI work at scale." />
  <section class="container max-w-6xl pb-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map(f => (
        <div class="rounded-2xl border border-border bg-card p-6">
          <h3 class="text-lg font-bold tracking-tight">{f.title}</h3>
          <p class="mt-3 text-foreground/75 leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
    <div class="mt-12 rounded-2xl border border-border bg-secondary p-8 md:p-10">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h2 class="text-xl md:text-2xl font-bold tracking-tight">Talk to sales</h2>
          <p class="mt-2 text-foreground/75">Tell us your team size, languages, and platforms. We'll quote within 1 business day.</p>
        </div>
        <a href="/contact?topic=enterprise" class="inline-flex shrink-0 items-center justify-center rounded-xl bg-primary text-primary-foreground px-6 h-11 font-semibold hover:bg-primary/90 transition-colors">Contact sales →</a>
      </div>
    </div>
  </section>
</Layout>
