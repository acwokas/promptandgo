---
import Layout from "@astro/layouts/Layout.astro";
import { sbFetch } from "@astro/lib/supabase-rest";

const data = await (async () => {
  try {
    const counts: any[] = await sbFetch(`/rest/v1/prompts?select=category_id&review_status=eq.approved`);
    const allCats: any[] = await sbFetch(`/rest/v1/categories?select=id,name,slug&order=name.asc`);
    const byCat: Record<string, number> = {};
    for (const r of counts) byCat[r.category_id] = (byCat[r.category_id] || 0) + 1;
    const cats = allCats
      .map((c: any) => ({ ...c, count: byCat[c.id] || 0 }))
      .filter((c: any) => c.slug !== "user-generated" && c.count > 0)
      .sort((a: any, b: any) => b.count - a.count);
    return { total: counts.length, cats };
  } catch (e) { return { total: 0, cats: [] }; }
})();
const total = data.total;
const cats = data.cats;

const featured = [
  { lang: "ja", title: "敬語ビジネスメール作成", what: "Polished Japanese business email with proper keigo." },
  { lang: "en", title: "Shopee Product Listing Optimiser", what: "SEO-friendly listing for Shopee, optimised for Singapore/Malaysia/Indonesia." },
  { lang: "zh", title: "WeChat Marketing Campaign Planner", what: "Native-feel campaign brief for mainland China." },
];

const platforms = ["ChatGPT", "Claude", "Gemini", "Mistral", "Grok", "DeepSeek", "Qwen", "Ernie Bot", "MidJourney"];
---
<Layout
  title="PromptAndGo — AI Prompts Built for Asia"
  description={`${total > 0 ? total : "1,000+"} curated AI prompts in 12+ Asian languages. Optimised for ChatGPT, Claude, Gemini, Mistral, Grok and more.`}
>
  <!-- HERO — clean, single column, value up front -->
  <section class="container max-w-4xl pt-16 md:pt-24 pb-12 md:pb-16 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-border bg-secondary/60 px-3.5 py-1.5 text-xs font-medium text-foreground/80 mb-7">
      <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
      {total > 0 ? `${total.toLocaleString()} prompts` : "1,000+ prompts"} · 12+ Asian languages · 5+ AI platforms
    </span>

    <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight leading-[1.05] text-foreground">
      AI prompts that
      <span class="text-gradient-brand">speak Asia fluently.</span>
    </h1>

    <p class="mt-6 text-lg md:text-xl text-foreground/80 max-w-2xl mx-auto leading-relaxed">
      Copy a vetted prompt. Tailor it for any AI platform. Ship work that respects the register, the market, and the language — built for Japan, Korea, China, SE Asia and India.
    </p>

    <div class="mt-9 flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/library"
         class="inline-flex items-center justify-center rounded-xl bg-primary text-primary-foreground px-7 h-12 text-base font-semibold hover:bg-primary/90 transition-colors">
        Browse the library →
      </a>
      <a href="/optimize"
         class="inline-flex items-center justify-center rounded-xl border-2 border-border bg-background hover:bg-secondary px-7 h-12 text-base font-semibold transition-colors">
        Try the optimiser — free
      </a>
    </div>
    <p class="mt-3 text-sm text-foreground/60">No signup required. Works with any AI account you already have.</p>
  </section>

  <!-- TRUST: PLATFORMS -->
  <section class="border-y border-border bg-secondary/40">
    <div class="container max-w-7xl py-6">
      <div class="flex flex-col md:flex-row md:items-center gap-3 md:gap-10">
        <div class="text-xs font-semibold uppercase tracking-wider text-foreground/60 shrink-0">Optimised for</div>
        <div class="overflow-hidden flex-1">
          <div class="marquee text-base md:text-lg font-semibold text-foreground/70">
            {[...platforms, ...platforms].map(p => <span class="whitespace-nowrap">{p}</span>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUE — three reasons, plain card layout -->
  <section class="container max-w-7xl py-16 md:py-24">
    <div class="max-w-2xl mb-12">
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight">Why PromptAndGo</h2>
      <p class="mt-4 text-lg text-foreground/75">Cultural awareness isn't a translation problem. We solve for context first.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      <article class="rounded-2xl border border-border bg-card p-7">
        <div class="w-11 h-11 rounded-xl bg-primary/10 text-primary grid place-items-center mb-5 text-xl">🌏</div>
        <h3 class="text-xl font-bold tracking-tight">Built for Asia</h3>
        <p class="mt-3 text-foreground/75 leading-relaxed">Japanese keigo, Korean honorifics, Mandarin tone, Singlish, Thai politeness levels. Out of the box.</p>
      </article>
      <article class="rounded-2xl border border-border bg-card p-7">
        <div class="w-11 h-11 rounded-xl bg-primary/10 text-primary grid place-items-center mb-5 text-xl">⚡</div>
        <h3 class="text-xl font-bold tracking-tight">Any AI Platform</h3>
        <p class="mt-3 text-foreground/75 leading-relaxed">ChatGPT, Claude, Gemini, Mistral, Grok, MidJourney — same intent, optimised for whichever model you use.</p>
      </article>
      <article class="rounded-2xl border border-border bg-card p-7">
        <div class="w-11 h-11 rounded-xl bg-primary/10 text-primary grid place-items-center mb-5 text-xl">🚀</div>
        <h3 class="text-xl font-bold tracking-tight">Ship work, not demos</h3>
        <p class="mt-3 text-foreground/75 leading-relaxed">Marketing, customer support, content, strategy — prompts vetted against the work professionals actually ship.</p>
      </article>
    </div>
  </section>

  <!-- LIBRARY PEEK — show category counts -->
  {cats.length > 0 && (
    <section class="container max-w-7xl py-16 md:py-20">
      <div class="flex items-end justify-between gap-4 mb-10">
        <div>
          <h2 class="text-3xl md:text-5xl font-bold tracking-tight">{total.toLocaleString()} prompts. {cats.length} categories.</h2>
          <p class="mt-3 text-lg text-foreground/75">Pick a category to start.</p>
        </div>
        <a href="/library" class="hidden sm:inline-flex shrink-0 items-center gap-2 text-sm font-semibold text-primary hover:underline">
          See all →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4">
        {cats.slice(0, 9).map(c => (
          <a href={`/library/${c.slug}`} class="group flex items-center justify-between gap-4 rounded-xl border border-border bg-card p-5 hover:border-primary/40 transition-colors">
            <div>
              <div class="text-base md:text-lg font-semibold text-foreground">{c.name}</div>
              <div class="mt-0.5 text-sm text-foreground/60">{c.count} prompts</div>
            </div>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="text-primary group-hover:translate-x-0.5 transition-transform"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- FEATURED MARKETS -->
  <section class="container max-w-7xl py-16 md:py-20">
    <div class="grid md:grid-cols-[1fr_2fr] gap-8 md:gap-12 items-start">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Pick your market.</h2>
        <p class="mt-3 text-lg text-foreground/75">Each landing has prompts and tone calibrated to that market.</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
        {[
          { href: "/ja", label: "日本語", sub: "Japanese" },
          { href: "/ko", label: "한국어", sub: "Korean" },
          { href: "/zh", label: "中文", sub: "Chinese" },
          { href: "/th", label: "ไทย", sub: "Thai" },
          { href: "/vi", label: "Tiếng Việt", sub: "Vietnamese" },
        ].map(t => (
          <a href={t.href} class="rounded-xl border border-border bg-card p-4 text-center hover:border-primary/40 transition-colors">
            <div class="text-xl md:text-2xl font-bold text-foreground" lang={t.href.replace("/","")}>{t.label}</div>
            <div class="mt-1 text-xs text-foreground/60">{t.sub}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA — solid, clean -->
  <section class="container max-w-7xl py-16 md:py-20">
    <div class="rounded-3xl border border-border bg-secondary p-10 md:p-14 text-center">
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight">Ship better AI work, faster.</h2>
      <p class="mt-4 text-lg text-foreground/75 max-w-2xl mx-auto">Free to browse. Free to optimise. Sign up only when you want to save your favourites.</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/library" class="inline-flex items-center justify-center rounded-xl bg-primary text-primary-foreground px-7 h-12 font-semibold hover:bg-primary/90 transition-colors">Browse the library →</a>
        <a href="/optimize" class="inline-flex items-center justify-center rounded-xl border-2 border-border bg-background hover:bg-card px-7 h-12 font-semibold transition-colors">Optimise a prompt — free</a>
      </div>
    </div>
  </section>
</Layout>
