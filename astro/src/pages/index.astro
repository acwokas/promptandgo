---
import "@astro/styles/global.css";
import HomepageIsland from "@astro/components/HomepageIsland";
const title = "PromptAndGo — AI Prompts for Asian Languages | Japanese, Korean, Chinese & More";
const description = "Create culturally-aware AI prompts in 12+ Asian languages. Optimize for ChatGPT, Claude, Gemini & more with keigo, honorifics, and regional context built in.";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0f0f23" />
    <meta name="color-scheme" content="light dark" />
    <meta name="author" content="PromptAndGo.ai" />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://www.promptandgo.ai/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://dkdakwyrqyfdkyukqmqs.supabase.co" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="icon" type="image/png" href="/uploads/favicon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <script is:inline>
      (function(){
        try {
          const t = localStorage.getItem('theme');
          if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <HomepageIsland client:only="react" />
  </body>
</html>
