---
import Layout from "@astro/layouts/Layout.astro";

const stats = [
  { n: "1,000+", label: "Curated prompts" },
  { n: "12", label: "Asian languages" },
  { n: "5", label: "AI platforms" },
  { n: "10k+", label: "Optimisations run" },
];

const pillars = [
  {
    icon: "🌏",
    title: "Built for Asia",
    body: "Japanese keigo, Korean honorifics, Mandarin tone, Singlish, Thai politeness levels — culturally aware out of the box, not a translation afterthought.",
    accent: "var(--brand-purple)",
  },
  {
    icon: "⚡",
    title: "Any AI Platform",
    body: "ChatGPT, Claude, Gemini, Mistral, Grok — same intent, optimised for whichever model you actually use. Compare side-by-side.",
    accent: "var(--brand-blue)",
  },
  {
    icon: "🚀",
    title: "Real Business Outcomes",
    body: "Marketing, customer support, content writing, strategy decks. Prompts vetted against the work professionals actually ship.",
    accent: "var(--brand-teal)",
  },
];

const languages = [
  { href: "/ja", label: "日本語", sub: "Japanese", sample: "敬語と丁寧語" },
  { href: "/ko", label: "한국어", sub: "Korean", sample: "존댓말 / 격식체" },
  { href: "/zh", label: "中文", sub: "Chinese", sample: "正式 vs 親切" },
  { href: "/th", label: "ไทย", sub: "Thai", sample: "ครับ / ค่ะ" },
  { href: "/vi", label: "Tiếng Việt", sub: "Vietnamese", sample: "Đại từ phù hợp" },
];

const useCases = [
  { who: "Marketers", what: "Localise campaigns across 5+ markets without losing voice." },
  { who: "Support teams", what: "Reply in customer's language, in your brand voice, instantly." },
  { who: "Founders", what: "Stand up AI workflows without a research team." },
  { who: "Content writers", what: "From outline to final draft, across formats." },
  { who: "Educators", what: "Build AI fluency with structured curricula." },
  { who: "Operators", what: "Document, summarise, and reformat at scale." },
];

const platforms = ["ChatGPT", "Claude", "Gemini", "Mistral", "Grok", "Llama"];

const tiersTeaser = [
  { name: "Free", price: "$0", note: "Browse + 5 optimisations / month" },
  { name: "Pro", price: "$12", note: "Unlimited optimisations · Power Packs", highlight: true },
  { name: "Team", price: "$32", note: "Per seat · shared libraries · audit log" },
];
---
<Layout
  title="PromptAndGo — AI Prompts for Asian Languages | Japanese, Korean, Chinese & More"
  description="Culturally-aware AI prompts in 12+ Asian languages. Optimised for ChatGPT, Claude, Gemini, Mistral, Grok. Built for teams shipping work, not demos."
>
  <!-- ============ HERO ============ -->
  <section class="relative overflow-hidden">
    <!-- Gradient orbs -->
    <div class="brand-orb w-[480px] h-[480px] -top-32 -left-24" style="background: hsl(var(--brand-purple));"></div>
    <div class="brand-orb w-[420px] h-[420px] top-20 right-[-120px]" style="background: hsl(var(--brand-teal));"></div>
    <div class="brand-orb w-[360px] h-[360px] bottom-[-120px] left-1/3" style="background: hsl(var(--brand-blue));"></div>

    <div class="relative container max-w-7xl pt-16 md:pt-24 pb-12 md:pb-16">
      <!-- Eyebrow -->
      <div class="flex flex-wrap items-center justify-center gap-2 mb-7">
        <span class="inline-flex items-center gap-1.5 rounded-full surface-glass px-3.5 py-1.5 text-xs font-medium">
          <span class="w-1.5 h-1.5 rounded-full bg-gradient-brand-animated"></span>
          New · Power Packs for marketing teams
        </span>
      </div>

      <h1 class="text-center text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.02] max-w-5xl mx-auto">
        AI prompts that
        <span class="block mt-2 text-gradient-brand">speak Asia fluently.</span>
      </h1>

      <p class="mt-6 text-center text-base md:text-xl text-foreground/70 max-w-2xl mx-auto leading-relaxed">
        From <strong>keigo</strong> in Tokyo to <strong>존댓말</strong> in Seoul, <strong>聲調</strong> in Taipei to <strong>ครับ/ค่ะ</strong> in Bangkok — prompts that understand the culture, then optimise for whichever AI you use.
      </p>

      <!-- CTAs -->
      <div class="mt-9 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/optimize" class="group inline-flex items-center justify-center rounded-xl bg-gradient-brand text-white px-7 h-12 text-sm md:text-base font-semibold shadow-brand hover:shadow-brand-lg transition-all">
          Optimise a prompt — free
          <svg class="ml-2 transition-transform group-hover:translate-x-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="/library" class="inline-flex items-center justify-center rounded-xl border border-border bg-card hover:bg-secondary px-7 h-12 text-sm md:text-base font-semibold transition-colors">
          Browse 1,000+ prompts
        </a>
      </div>
      <p class="mt-3.5 text-center text-xs text-muted-foreground">No signup required · Works with the free tier of any AI</p>

      <!-- Hero visual: animated multilingual prompt examples -->
      <div class="relative mt-14 md:mt-20 max-w-4xl mx-auto">
        <div class="absolute -inset-2 bg-gradient-brand opacity-20 blur-2xl rounded-3xl"></div>
        <div class="relative rounded-2xl surface-glass p-1.5 shadow-brand-lg">
          <div class="rounded-xl bg-card overflow-hidden">
            <!-- Top tab bar -->
            <div class="flex items-center gap-2 px-5 py-3 border-b border-border/50">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-destructive/70"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/70"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-400/70"></div>
              </div>
              <div class="flex-1 mx-3 h-7 rounded-md bg-secondary/60 px-3 flex items-center text-xs text-muted-foreground font-mono">
                promptandgo.ai/optimize
              </div>
            </div>
            <!-- Content -->
            <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-border/50">
              <div class="p-5 md:p-6">
                <div class="text-[10px] font-semibold uppercase tracking-wider text-muted-foreground mb-2">Your prompt</div>
                <p class="text-sm leading-relaxed">Write a polite follow-up email to a Japanese client who hasn't replied to my previous message about the proposal.</p>
                <div class="mt-4 flex flex-wrap gap-1.5">
                  <span class="inline-flex items-center rounded-md bg-secondary px-2 py-0.5 text-[10px] font-medium">JA</span>
                  <span class="inline-flex items-center rounded-md bg-secondary px-2 py-0.5 text-[10px] font-medium">B2B</span>
                  <span class="inline-flex items-center rounded-md bg-secondary px-2 py-0.5 text-[10px] font-medium">Email</span>
                </div>
              </div>
              <div class="p-5 md:p-6 bg-gradient-brand-soft">
                <div class="text-[10px] font-semibold uppercase tracking-wider text-muted-foreground mb-2">Optimised for Claude · ja-JP</div>
                <p class="text-sm leading-relaxed font-medium" lang="ja">
                  〇〇様<br />
                  いつもお世話になっております。先日ご提案させていただいた件につきまして、ご検討状況はいかがでしょうか。お忙しいところ恐れ入りますが…
                </p>
                <div class="mt-4 inline-flex items-center gap-1.5 text-xs text-muted-foreground">
                  <span class="w-1.5 h-1.5 rounded-full" style="background: hsl(var(--brand-teal));"></span>
                  Keigo: respectful · Tone: warm-formal
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TRUST STRIP / PLATFORMS ============ -->
  <section class="relative border-y border-border/50 bg-secondary/40">
    <div class="container max-w-7xl py-7">
      <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-10">
        <div class="text-xs font-semibold uppercase tracking-wider text-muted-foreground shrink-0">
          Optimised for
        </div>
        <div class="overflow-hidden">
          <div class="marquee gap-12 text-base md:text-lg font-semibold text-foreground/60">
            {[...platforms, ...platforms].map(p => (
              <span class="whitespace-nowrap">{p}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ STATS ============ -->
  <section class="container max-w-7xl py-14 md:py-20">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {stats.map(s => (
        <div class="rounded-2xl surface-glass p-6 md:p-7 text-center">
          <div class="text-3xl md:text-5xl font-extrabold text-gradient-brand tracking-tight">{s.n}</div>
          <div class="mt-1 text-xs md:text-sm text-muted-foreground">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ THREE PILLARS ============ -->
  <section class="container max-w-7xl py-14 md:py-20">
    <div class="text-center max-w-2xl mx-auto mb-12 md:mb-16">
      <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Why PromptAndGo</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold tracking-tight">Cultural awareness isn't a translation problem.</h2>
      <p class="mt-4 text-lg text-foreground/70">It's a context problem. We solve for context first.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-5 md:gap-6">
      {pillars.map(p => (
        <article class="card-lift relative rounded-2xl bg-card border border-border/60 p-7 md:p-8 overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1" style={`background: linear-gradient(90deg, transparent, hsl(${p.accent}), transparent)`}></div>
          <div class="text-3xl mb-5">{p.icon}</div>
          <h3 class="text-xl md:text-2xl font-bold tracking-tight">{p.title}</h3>
          <p class="mt-3 text-foreground/70 leading-relaxed">{p.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="container max-w-7xl py-14 md:py-20">
    <div class="grid lg:grid-cols-[5fr_7fr] gap-10 lg:gap-16 items-center">
      <div>
        <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">How it works</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight">Idea → AI output that ships.<br />In 4 steps.</h2>
        <p class="mt-4 text-foreground/70 leading-relaxed">
          Most prompt tools optimise <em>generic</em> prompts. We optimise for the <strong>platform</strong> you're on, the <strong>language</strong> you're targeting, and the <strong>register</strong> your audience expects.
        </p>
        <a href="/how-it-works" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline">
          Read the deep dive
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
      <ol class="space-y-3">
        {[
          { n: 1, t: "Pick or describe", d: "Choose from 1,000+ vetted prompts, or describe what you need." },
          { n: 2, t: "Pick your platform", d: "ChatGPT, Claude, Gemini — or compare side-by-side." },
          { n: 3, t: "We optimise", d: "Rewrite for the chosen model AND your target language." },
          { n: 4, t: "Run, save, share", d: "Use your AI account; save what works; share with shortlinks." },
        ].map(s => (
          <li class="flex gap-5 rounded-xl bg-card border border-border/60 p-5 card-lift">
            <div class="shrink-0 w-11 h-11 rounded-xl bg-gradient-brand text-white font-bold grid place-items-center shadow-brand">
              {s.n}
            </div>
            <div>
              <h3 class="font-semibold text-base md:text-lg">{s.t}</h3>
              <p class="mt-0.5 text-sm text-foreground/70">{s.d}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============ LANGUAGES ============ -->
  <section class="container max-w-7xl py-14 md:py-20">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">By market</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold tracking-tight">Pick the market you sell to.</h2>
      <p class="mt-4 text-lg text-foreground/70">Each landing has prompts, examples, and tone calibrated to that market.</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3 md:gap-4">
      {languages.map(l => (
        <a href={l.href} class="card-lift relative rounded-2xl bg-card border border-border/60 p-5 md:p-6 text-center group">
          <div class="text-2xl md:text-3xl font-bold mb-2" lang={l.href.replace("/","")}>{l.label}</div>
          <div class="text-xs text-muted-foreground mb-3">{l.sub}</div>
          <div class="text-xs text-muted-foreground/80 italic" lang={l.href.replace("/","")}>{l.sample}</div>
          <div class="mt-4 text-xs font-semibold text-primary opacity-0 group-hover:opacity-100 transition-opacity">Explore →</div>
        </a>
      ))}
    </div>
  </section>

  <!-- ============ USE CASES ============ -->
  <section class="container max-w-7xl py-14 md:py-20">
    <div class="grid md:grid-cols-3 gap-x-10 gap-y-8">
      <div>
        <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">For teams</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight">Built for the people<br />actually doing the work.</h2>
        <p class="mt-4 text-foreground/70">Six teams use PromptAndGo every week. They don't have time to babysit prompts.</p>
        <a href="/use-cases" class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline">
          See all use cases →
        </a>
      </div>
      <div class="md:col-span-2 grid sm:grid-cols-2 gap-3">
        {useCases.map(uc => (
          <div class="rounded-xl bg-card border border-border/60 p-5 card-lift">
            <h3 class="font-semibold">{uc.who}</h3>
            <p class="mt-1.5 text-sm text-foreground/70 leading-relaxed">{uc.what}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PRICING TEASER ============ -->
  <section class="container max-w-7xl py-14 md:py-20">
    <div class="rounded-3xl border border-border/60 bg-gradient-brand-soft p-8 md:p-12">
      <div class="grid lg:grid-cols-[3fr_5fr] gap-8 lg:gap-12 items-center">
        <div>
          <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Pricing</span>
          <h2 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight">Start free.<br />Scale as you ship.</h2>
          <p class="mt-4 text-foreground/70">Free forever for browsing and lighter use. Cancel anytime.</p>
          <a href="/pricing" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline">
            Full pricing →
          </a>
        </div>
        <div class="grid sm:grid-cols-3 gap-3">
          {tiersTeaser.map(t => (
            <div class={`rounded-2xl p-5 border ${t.highlight ? 'border-primary/40 bg-card shadow-brand' : 'border-border/60 bg-card'}`}>
              {t.highlight && <span class="inline-block text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full bg-gradient-brand text-white mb-2">Most popular</span>}
              <div class="font-semibold">{t.name}</div>
              <div class="mt-1 text-2xl font-extrabold">{t.price}</div>
              <div class="mt-2 text-xs text-foreground/70">{t.note}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FINAL CTA ============ -->
  <section class="container max-w-7xl py-14 md:py-20">
    <div class="relative rounded-3xl overflow-hidden">
      <div class="absolute inset-0 bg-gradient-brand-animated"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(255,255,255,0.18),transparent_50%)]"></div>
      <div class="relative p-10 md:p-16 text-center text-white">
        <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight">Ship better AI work, faster.</h2>
        <p class="mt-4 text-lg text-white/90 max-w-2xl mx-auto">
          Stop tweaking prompts at midnight. Use vetted, culturally-aware prompts across every platform — in every language.
        </p>
        <div class="mt-9 flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/auth?action=signup" class="inline-flex items-center justify-center rounded-xl bg-white text-primary px-8 h-12 font-semibold hover:bg-white/95 transition-colors">
            Start free — no card
          </a>
          <a href="/pricing" class="inline-flex items-center justify-center rounded-xl border border-white/40 text-white px-8 h-12 font-semibold hover:bg-white/10 transition-colors">
            See pricing
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
