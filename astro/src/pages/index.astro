---
import Layout from "@/layouts/Layout.astro";
const features = [
  { title: "Built for Asia", desc: "Japanese keigo, Korean honorifics, Mandarin tone, Singlish, Thai politeness levels — culturally aware out of the box." },
  { title: "Any AI Platform", desc: "ChatGPT, Claude, Gemini, Mistral, Grok — same prompt, optimized for whichever model you use." },
  { title: "Real Business Outcomes", desc: "Marketing, customer support, content writing, strategy decks — prompts proven to ship work, not just demos." },
  { title: "Power Packs", desc: "Curated bundles of 30+ prompts for specific roles and verticals. Drop-in for entire workflows." },
];
const stats = [
  { n: "12+", label: "Asian languages" },
  { n: "500+", label: "Curated prompts" },
  { n: "5+", label: "AI platforms supported" },
  { n: "10k+", label: "Prompt optimisations run" },
];
---
<Layout
  title="PromptAndGo — AI Prompts for Asian Languages | Japanese, Korean, Chinese & More"
  description="Create culturally-aware AI prompts in 12+ Asian languages. Optimize for ChatGPT, Claude, Gemini & more with keigo, honorifics, and regional context built in."
>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-secondary/50 via-background to-background"></div>
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full -z-10 opacity-40 blur-3xl"
      style="background: radial-gradient(closest-side, hsl(350 78% 59% / 0.4), transparent 70%);"></div>
    <div class="container py-16 md:py-24 lg:py-32">
      <div class="flex flex-wrap justify-center gap-2 mb-6">
        <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 text-primary border border-primary/20 px-3 py-1 text-sm font-medium">🌏 Built for Asia</span>
        <span class="inline-flex items-center gap-1 rounded-full bg-accent/10 text-accent border border-accent/20 px-3 py-1 text-sm font-medium">⚡ Any Platform · Any Language</span>
      </div>
      <h1 class="text-center text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05] max-w-4xl mx-auto">
        The only AI prompt tool
        <span class="block mt-2"><span class="text-gradient-brand">built for Asia.</span></span>
      </h1>
      <p class="mt-4 text-center text-lg md:text-xl text-foreground/80 font-medium">
        <span class="block">开始写出色的提示词</span>
      </p>
      <p class="mt-6 text-center text-base md:text-lg text-muted-foreground max-w-2xl mx-auto">
        Prompts that understand Japanese business formality, Southeast Asian market dynamics, Mandarin tone, and Indian enterprise context — then optimize them for <strong>any AI platform</strong> in <strong>any language</strong>.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/optimize" class="inline-flex items-center justify-center rounded-lg bg-gradient-primary text-primary-foreground px-8 py-4 text-base font-semibold shadow-glow hover:opacity-95 transition-all">
          ⚡ Optimize for Any Platform — Free
        </a>
        <a href="/library" class="inline-flex items-center justify-center rounded-lg border border-border bg-card hover:bg-secondary px-8 py-4 text-base font-semibold transition-colors">
          🌐 Explore Asian AI Prompts
        </a>
      </div>
      <p class="mt-3 text-center text-sm text-muted-foreground">No signup required. Start optimizing instantly.</p>
    </div>
  </section>

  <!-- STATS -->
  <section class="container py-8 md:py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 text-center">
      {stats.map(s => (
        <div class="rounded-xl bg-card border border-border/60 p-6">
          <div class="text-3xl md:text-4xl font-bold text-gradient-brand">{s.n}</div>
          <div class="mt-1 text-sm text-muted-foreground">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- FEATURES -->
  <section class="container py-16 md:py-20">
    <div class="text-center max-w-2xl mx-auto mb-10 md:mb-14">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Why PromptAndGo</h2>
      <p class="mt-3 text-muted-foreground">Cultural awareness isn't a translation problem. It's a context problem.</p>
    </div>
    <div class="grid md:grid-cols-2 gap-5 md:gap-6">
      {features.map(f => (
        <div class="rounded-2xl bg-card border border-border/60 p-6 md:p-8 hover:border-primary/40 transition-colors">
          <h3 class="text-xl font-semibold">{f.title}</h3>
          <p class="mt-2 text-muted-foreground leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- LANGUAGE TILES -->
  <section class="container py-16 md:py-20">
    <div class="text-center max-w-2xl mx-auto mb-10">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Pick your market</h2>
      <p class="mt-3 text-muted-foreground">Tailored prompts and language-aware optimization for each.</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3 md:gap-4">
      {[
        { href: "/ja", label: "日本語", sub: "Japanese" },
        { href: "/ko", label: "한국어", sub: "Korean" },
        { href: "/zh", label: "中文", sub: "Chinese" },
        { href: "/th", label: "ไทย", sub: "Thai" },
        { href: "/vi", label: "Tiếng Việt", sub: "Vietnamese" },
      ].map(t => (
        <a href={t.href} class="rounded-xl bg-card border border-border/60 p-5 text-center hover:border-primary/40 hover:shadow-glow transition-all">
          <div class="text-2xl font-semibold">{t.label}</div>
          <div class="mt-1 text-xs text-muted-foreground">{t.sub}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="container py-16 md:py-20">
    <div class="rounded-3xl bg-gradient-primary p-10 md:p-14 text-center text-primary-foreground shadow-glow">
      <h2 class="text-3xl md:text-4xl font-bold">Ship better AI work, faster.</h2>
      <p class="mt-3 text-primary-foreground/90 max-w-xl mx-auto">Stop tweaking prompts at midnight. Use vetted, culturally-aware prompts across every platform.</p>
      <div class="mt-7 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/auth" class="inline-flex items-center justify-center rounded-lg bg-white text-primary px-8 py-3 text-base font-semibold hover:bg-white/95 transition-colors">Sign up — free</a>
        <a href="/pricing" class="inline-flex items-center justify-center rounded-lg border border-white/40 px-8 py-3 text-base font-semibold hover:bg-white/10 transition-colors">See pricing</a>
      </div>
    </div>
  </section>
</Layout>
