---
import Layout from "@astro/layouts/Layout.astro";
import PromptCard from "@astro/components/PromptCard.astro";
import PromptLock from "@astro/components/PromptLock.tsx";
import FavouriteButton from "@astro/components/FavouriteButton.tsx";
import { sbFetch } from "@astro/lib/supabase-rest";

export async function getStaticPaths() {
  try {
    const cats: any[] = await sbFetch(`/rest/v1/categories?select=id,name,slug`);
    const subs: any[] = await sbFetch(`/rest/v1/subcategories?select=id,name,slug,category_id`);
    const subById: Record<string, any> = Object.fromEntries(subs.map((s: any) => [s.id, s]));
    const catById: Record<string, any> = Object.fromEntries(cats.map((c: any) => [c.id, c]));
    const prompts: any[] = await sbFetch(
      `/rest/v1/prompts?select=id,slug,title,what_for,prompt,excerpt,image_prompt,category_id,subcategory_id,is_pro,ribbon&review_status=eq.approved&order=created_at.desc&limit=1500`
    );
    const allPacks: any[] = await sbFetch(`/rest/v1/packs?select=id,slug,name,price_cents&is_active=eq.true`);
    const packPrompts: any[] = await sbFetch(`/rest/v1/pack_prompts?select=pack_id,prompt_id`);
    const packsByPrompt: Record<string, any[]> = {};
    const packById = Object.fromEntries(allPacks.map(p => [p.id, p]));
    for (const r of packPrompts) {
      const pk = packById[r.pack_id];
      if (!pk) continue;
      (packsByPrompt[r.prompt_id] ||= []).push(pk);
    }

    // Pre-compute related per prompt
    const bySub: Record<string, any[]> = {};
    const byCat: Record<string, any[]> = {};
    for (const p of prompts) {
      if (p.subcategory_id) (bySub[p.subcategory_id] ||= []).push(p);
      (byCat[p.category_id] ||= []).push(p);
    }

    return prompts
      .filter((p: any) => catById[p.category_id] && p.slug)
      .map((p: any) => {
        const cat = catById[p.category_id];
        const sub = p.subcategory_id ? subById[p.subcategory_id] : null;
        const pool = sub ? bySub[sub.id] : byCat[cat.id];
        const related = (pool || [])
          .filter((q: any) => q.slug !== p.slug)
          .slice(0, 3)
          .map((q: any) => ({
            slug: q.slug, title: q.title, excerpt: q.excerpt, what_for: q.what_for,
            category_id: q.category_id, subcategory_id: q.subcategory_id,
          }));
        const packsForThis = packsByPrompt[p.id] || [];
        const cheapest = packsForThis.sort((a, b) => (a.price_cents || 0) - (b.price_cents || 0))[0] || null;
        return {
          params: { category: cat.slug, slug: p.slug },
          props: { prompt: p, category: cat, subcategory: sub, related, allCats: cats, allSubs: subs, packIds: packsForThis.map(x => x.id), cheapestPack: cheapest },
        };
      });
  } catch (e) {
    console.error("getStaticPaths failed:", e);
    return [];
  }
}

const { prompt, category, subcategory, related, allCats, allSubs, packIds, cheapestPack } = Astro.props as any;
const catById = Object.fromEntries(allCats.map((c: any) => [c.id, c]));
const subById = Object.fromEntries(allSubs.map((s: any) => [s.id, s]));

const ld = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: prompt.title,
  description: prompt.what_for || prompt.excerpt,
  text: prompt.is_pro ? undefined : prompt.prompt,
  inLanguage: "en",
  about: { "@type": "Thing", name: category.name },
  isPartOf: { "@type": "Collection", name: "PromptAndGo AI Prompt Library", url: "https://www.promptandgo.ai/library" },
  url: `https://www.promptandgo.ai/library/${category.slug}/${prompt.slug}`,
  ...(prompt.is_pro ? { offers: { "@type": "Offer", price: "1.99", priceCurrency: "USD", availability: "https://schema.org/InStock" } } : {}),
};
---
<Layout
  title={`${prompt.title} — ${category.name} AI Prompt | PromptAndGo`}
  description={prompt.excerpt || prompt.what_for || `${prompt.title} — ready-to-use AI prompt from PromptAndGo.`}
  canonical={`https://www.promptandgo.ai/library/${category.slug}/${prompt.slug}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(ld)}></script>

  <section class="container max-w-3xl pt-10 md:pt-14 pb-6">
    <nav class="text-sm text-foreground/60 mb-6 flex items-center gap-2 flex-wrap" aria-label="Breadcrumb">
      <a href="/library" class="hover:text-foreground">Library</a>
      <span class="text-foreground/40">/</span>
      <a href={`/library/${category.slug}`} class="hover:text-foreground">{category.name}</a>
      {subcategory && <><span class="text-foreground/40">/</span><span class="text-foreground/85">{subcategory.name}</span></>}
    </nav>
    <div class="flex flex-wrap items-center gap-2 mb-4">
      {category && <span class="rounded-md bg-primary/10 text-primary px-2 py-0.5 text-xs font-medium">{category.name}</span>}
      {subcategory && <span class="text-xs text-foreground/55">{subcategory.name}</span>}
      {prompt.is_pro && <span class="inline-flex items-center gap-1 rounded-md bg-amber-500/10 text-amber-700 dark:text-amber-300 px-2 py-0.5 text-xs font-bold uppercase tracking-wider">
        <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1l3 7h7l-5.5 4.5L18 20l-6-4-6 4 1.5-7.5L2 8h7z"/></svg>
        Premium
      </span>}
      {prompt.ribbon && <span class="rounded-md bg-secondary text-foreground/85 px-2 py-0.5 text-xs font-medium">{prompt.ribbon}</span>}
    </div>
    <div class="flex items-start justify-between gap-4">
      <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight leading-tight">{prompt.title}</h1>
      <div class="shrink-0 mt-1"><FavouriteButton client:load promptId={prompt.id} /></div>
    </div>
    {prompt.what_for && <p class="mt-4 text-lg text-foreground/80 leading-relaxed">{prompt.what_for}</p>}
  </section>

  <article class="container max-w-3xl pb-12">
    <PromptLock
      client:load
      promptId={prompt.id}
      promptBody={prompt.prompt}
      imagePrompt={prompt.image_prompt}
      isPro={prompt.is_pro}
      packIds={packIds || []}
      cheapestPack={cheapestPack}
      promptTitle={prompt.title}
    />

    <div class="mt-6 flex flex-wrap gap-3">
      <a href={`/optimize?prompt=${encodeURIComponent(prompt.is_pro ? "" : (prompt.prompt || ""))}&title=${encodeURIComponent(prompt.title || "")}&category=${encodeURIComponent(category.name || "")}`}
         class="inline-flex items-center justify-center rounded-xl bg-primary text-primary-foreground px-5 h-11 font-semibold hover:bg-primary/90 transition-colors">⚡ Optimise this for any AI →</a>
      <a href={`/library/${category.slug}`} class="inline-flex items-center justify-center rounded-xl border-2 border-border bg-background hover:bg-secondary px-5 h-11 font-semibold transition-colors">More {category.name} prompts</a>
    </div>
  </article>

  {related && related.length > 0 && (
    <section class="container max-w-6xl pb-20">
      <h2 class="text-xl md:text-2xl font-bold tracking-tight mb-5">More like this</h2>
      <div class="grid md:grid-cols-3 gap-4">
        {related.map((r: any) => {
          const c = catById[r.category_id];
          const s = subById[r.subcategory_id];
          if (!c) return null;
          return <PromptCard prompt={r} href={`/library/${c.slug}/${r.slug}`} subcategory={s?.name} />;
        })}
      </div>
    </section>
  )}
</Layout>
