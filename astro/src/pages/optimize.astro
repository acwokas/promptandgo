---
import Layout from "@astro/layouts/Layout.astro";
import OptimizerForm from "@astro/components/OptimizerForm.tsx";

const platforms = ["ChatGPT", "Claude", "Gemini", "Mistral", "Grok", "DeepSeek", "Qwen", "Ernie Bot", "MidJourney"];
const languages = [
  { code: "ja", label: "日本語", desc: "Keigo, sonkeigo, kenjougo — relationship-aware" },
  { code: "ko", label: "한국어", desc: "존댓말 / 격식체 — speech levels" },
  { code: "zh", label: "中文", desc: "正式 vs 親切 — register and tone" },
  { code: "th", label: "ไทย", desc: "ครับ / ค่ะ — politeness particles" },
  { code: "vi", label: "Tiếng Việt", desc: "Đại từ phù hợp — pronoun selection" },
];
const examples = [
  {
    bad: "Write me a marketing email",
    good: "Write a 150-word marketing email for [product] targeting [audience]. Use a professional but friendly tone. Include: 1) attention-grabbing subject line, 2) one clear benefit, 3) social proof element, 4) specific call-to-action. Avoid: hype, jargon, multiple CTAs.",
    why: "Specific length, tone, structure, and constraints turn a generic ask into a copy-ready brief.",
  },
  {
    bad: "Email a Japanese client about delayed delivery",
    good: "Write a 200-word business email in Japanese (敬語) to a senior Japanese client (use 様) apologising for a 3-day delivery delay. Tone: deeply respectful, taking ownership without excuses. Include: 1) formal opening (お世話になっております), 2) clear apology, 3) cause, 4) corrective action with specific date, 5) closing assurance.",
    why: "Asks for keigo explicitly, specifies the honorific, and structures the apology in the way Japanese B2B clients expect.",
  },
  {
    bad: "Make me a marketing image of bubble tea",
    good: "Aesthetic flat-lay photo of artisanal bubble tea, tapioca pearls visible through clear cup, Southeast Asian street market background, neon signage in Chinese and Malay, tropical flowers, warm golden hour lighting, Gen Z lifestyle photography. Shot on Sony A7III, 35mm lens. --ar 4:5 --v 6 --style raw",
    why: "Image models reward specificity in subject + style + composition + lighting. Aspect ratio and version flags matter on MidJourney.",
  },
];
---
<Layout
  title="Free AI Prompt Optimiser — Any Platform, Any Language | PromptAndGo"
  description="Free AI prompt optimiser for ChatGPT, Claude, Gemini, Mistral, Grok, MidJourney, and more. Built for Asian languages — keigo, honorifics, market-aware tone. No signup required."
  canonical="https://www.promptandgo.ai/optimize"
>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    
    

    <div class="relative container max-w-5xl pt-14 md:pt-20 pb-10">
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-flex items-center gap-2 rounded-full surface-glass px-3.5 py-1.5 text-xs font-semibold mb-6">
          ⚡ Free · No signup · Streams in real-time
        </span>
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight leading-[1.05]">
          Optimise any prompt for <span class="text-gradient-brand">any AI</span> in <span class="text-gradient-brand">any language</span>.
        </h1>
        <p class="mt-5 text-lg text-foreground/70 max-w-2xl mx-auto">
          Paste a rough prompt, pick the platform and target language. We rewrite it with the right structure, register, and cultural awareness — explained.
        </p>
      </div>

      <!-- The actual interactive optimizer -->
      <div class="mt-10 md:mt-12">
        <OptimizerForm client:visible />
      </div>
    </div>
  </section>

  <!-- TRUST: PLATFORMS -->
  <section class="border-y border-border/50 bg-secondary/40">
    <div class="container max-w-7xl py-7">
      <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-10">
        <div class="text-xs font-semibold uppercase tracking-wider text-muted-foreground shrink-0">Optimised for</div>
        <div class="overflow-hidden">
          <div class="marquee gap-12 text-base md:text-lg font-semibold text-foreground/60">
            {[...platforms, ...platforms].map(p => <span class="whitespace-nowrap">{p}</span>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY ASIAN LANGUAGE NUANCE MATTERS -->
  <section class="container max-w-6xl py-14 md:py-20">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">What we get right</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold tracking-tight">Cultural register, <span class="text-gradient-brand">not just translation</span>.</h2>
      <p class="mt-4 text-lg text-foreground/70">Generic optimisers translate words. We adjust register, hierarchy, and politeness for the actual market.</p>
    </div>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {languages.map(l => (
        <div class="rounded-2xl bg-card border border-border/60 p-6 card-lift" lang={l.code}>
          <div class="text-2xl font-bold mb-2">{l.label}</div>
          <p class="text-sm text-foreground/70 leading-relaxed">{l.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- BEFORE/AFTER EXAMPLES -->
  <section class="container max-w-5xl py-14 md:py-20">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Before / After</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold tracking-tight">Three real <span class="text-gradient-brand">optimisations</span>.</h2>
    </div>
    <div class="space-y-5">
      {examples.map((ex, i) => (
        <div class="rounded-2xl border border-border/60 bg-card overflow-hidden">
          <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-border/50">
            <div class="p-5 md:p-6">
              <div class="text-[10px] font-semibold uppercase tracking-wider text-muted-foreground mb-2">Before</div>
              <p class="text-sm md:text-base font-medium leading-relaxed">{ex.bad}</p>
            </div>
            <div class="p-5 md:p-6 bg-gradient-brand-soft">
              <div class="text-[10px] font-semibold uppercase tracking-wider text-muted-foreground mb-2">After (optimised)</div>
              <p class="text-sm md:text-base leading-relaxed whitespace-pre-line">{ex.good}</p>
            </div>
          </div>
          <div class="px-5 md:px-6 py-4 border-t border-border/50 text-sm text-foreground/70">
            <strong class="text-foreground">Why it works:</strong> {ex.why}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="container max-w-3xl py-14 md:py-20">
    <div class="text-center mb-10">
      <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">FAQ</span>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight">About the optimiser</h2>
    </div>
    <div class="divide-y divide-border/60 rounded-2xl border border-border/60 bg-card">
      {[
        { q: "Is it actually free?", a: "Yes. The web optimiser has a free tier (5 optimisations/month) with no signup. Pro accounts get unlimited use plus saved history and side-by-side platform compare." },
        { q: "Do you store my prompts?", a: "Anonymous use: nothing stored. Logged-in use: your saved prompts stay private under your account." },
        { q: "Which AI platforms do you support?", a: "ChatGPT, Claude, Gemini, Mistral, Grok, DeepSeek, Perplexity, Copilot, MidJourney, Stable Diffusion, Qwen, Ernie, Meta AI." },
        { q: "Why does Asian language nuance matter?", a: "Pragmatics and politeness in CJK and Southeast Asian languages aren't optional politeness — they encode the relationship and the situation. Get them wrong and your output reads as cold, presumptuous, or amateur." },
        { q: "Can I use this for image prompts (MidJourney, Stable Diffusion)?", a: "Yes. Pick the image model and we adjust the optimisation to focus on subject, style, composition, lighting, and platform-specific parameters." },
      ].map(f => (
        <details class="group p-5 cursor-pointer">
          <summary class="flex items-center justify-between gap-4 list-none">
            <span class="font-semibold">{f.q}</span>
            <span class="text-muted-foreground transition-transform group-open:rotate-45 text-xl leading-none">+</span>
          </summary>
          <p class="mt-3 text-sm text-foreground/70 leading-relaxed">{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="container max-w-7xl py-14 md:py-20">
    <div class="relative rounded-3xl overflow-hidden">
      <div class="absolute inset-0 bg-gradient-brand-animated"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(255,255,255,0.18),transparent_50%)]"></div>
      <div class="relative p-10 md:p-14 text-center text-white">
        <h2 class="text-3xl md:text-4xl font-extrabold">Ready to ship better AI work?</h2>
        <p class="mt-3 text-white/90 max-w-2xl mx-auto">Sign up free for unlimited optimisations and the full prompt library.</p>
        <div class="mt-7 flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/auth?action=signup" class="inline-flex items-center justify-center rounded-xl bg-white text-primary px-8 h-12 font-semibold hover:bg-white/95 transition-colors">Sign up — free</a>
          <a href="/library" class="inline-flex items-center justify-center rounded-xl border border-white/40 text-white px-8 h-12 font-semibold hover:bg-white/10 transition-colors">Browse the library</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
