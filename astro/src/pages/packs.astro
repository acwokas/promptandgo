---
import Layout from "@astro/layouts/Layout.astro";
import { sbFetch } from "@astro/lib/supabase-rest";

const data = await (async () => {
  try {
    const packs: any[] = await sbFetch(`/rest/v1/packs?select=id,name,slug,description,price_cents,is_active&is_active=eq.true&order=name.asc`);
    const pp: any[] = await sbFetch(`/rest/v1/pack_prompts?select=pack_id,prompts(is_pro)`);
    const counts: Record<string, { total: number; premium: number }> = {};
    for (const r of pp) {
      counts[r.pack_id] ||= { total: 0, premium: 0 };
      counts[r.pack_id].total++;
      if (r.prompts?.is_pro) counts[r.pack_id].premium++;
    }
    return packs.map(p => ({ ...p, ...counts[p.id] || { total: 0, premium: 0 } }));
  } catch (e) { return []; }
})();
---
<Layout
  title="Power Packs — Curated AI Prompt Bundles | PromptAndGo"
  description={`${data.length} curated prompt packs for landing jobs, launching campaigns, building content, supporting customers. Premium prompts unlocked individually or by pack.`}
>
  <section class="container max-w-4xl pt-14 md:pt-20 pb-10 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-border bg-secondary/60 px-3.5 py-1.5 text-xs font-medium text-foreground/80 mb-6">Power Packs</span>
    <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight leading-tight">
      Curated bundles. <span class="text-gradient-brand">Real outcomes.</span>
    </h1>
    <p class="mt-5 text-lg text-foreground/80 max-w-2xl mx-auto">
      10–15 prompts per pack, hand-picked for one specific outcome. Buy a pack, unlock a single premium prompt, or subscribe to unlock everything.
    </p>
  </section>

  <!-- Pricing options banner -->
  <section class="container max-w-5xl pb-10">
    <div class="rounded-2xl border border-border bg-secondary/40 p-6 md:p-8">
      <div class="grid sm:grid-cols-3 gap-5">
        <div>
          <div class="text-xs font-semibold uppercase tracking-wider text-foreground/60">Single prompt</div>
          <div class="mt-2 text-2xl font-extrabold">$1.99</div>
          <div class="mt-1 text-sm text-foreground/70">Unlock individual premium prompts.</div>
        </div>
        <div class="border-t sm:border-t-0 sm:border-l border-border pt-5 sm:pt-0 sm:pl-5">
          <div class="text-xs font-semibold uppercase tracking-wider text-foreground/60">Whole pack</div>
          <div class="mt-2 text-2xl font-extrabold">$7.99–14.99</div>
          <div class="mt-1 text-sm text-foreground/70">Unlock every prompt in the pack.</div>
        </div>
        <div class="border-t sm:border-t-0 sm:border-l border-border pt-5 sm:pt-0 sm:pl-5">
          <div class="text-xs font-semibold uppercase tracking-wider text-foreground/60">All-you-can-eat</div>
          <div class="mt-2 text-2xl font-extrabold">$12<span class="text-sm font-medium text-foreground/60">/mo</span></div>
          <div class="mt-1 text-sm text-foreground/70">Unlimited access. Or $120/year (save 17%).</div>
        </div>
      </div>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/auth?action=signup&plan=monthly" class="inline-flex items-center justify-center rounded-xl bg-primary text-primary-foreground px-5 h-11 font-semibold hover:bg-primary/90 transition-colors">Subscribe — $12/mo</a>
        <a href="/pricing" class="inline-flex items-center justify-center rounded-xl border-2 border-border bg-background hover:bg-card px-5 h-11 font-semibold transition-colors">See full pricing</a>
      </div>
    </div>
  </section>

  <!-- Pack grid -->
  <section class="container max-w-7xl pb-16">
    {data.length === 0 && (
      <div class="rounded-2xl border border-border bg-card p-10 text-center text-foreground/60">No active packs yet.</div>
    )}
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {data.map((p: any) => (
        <a href={`/packs/${p.slug}`} class="group rounded-2xl border border-border bg-card p-6 flex flex-col hover:border-primary/40 transition-colors">
          <div class="flex items-start justify-between gap-3 mb-4">
            <span class="rounded-md bg-primary/10 text-primary px-2 py-0.5 text-xs font-medium">{p.total ?? 0} prompts</span>
            <span class="text-base font-extrabold">${(p.price_cents / 100).toFixed(2)}</span>
          </div>
          <h2 class="text-lg md:text-xl font-bold tracking-tight">{p.name}</h2>
          <p class="mt-2 text-sm text-foreground/75 leading-relaxed flex-1 line-clamp-3">{p.description}</p>
          <div class="mt-4 flex items-center justify-between gap-3 text-xs text-foreground/60">
            {(p.premium ?? 0) > 0 && <span class="inline-flex items-center gap-1.5"><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1l3 7h7l-5.5 4.5L18 20l-6-4-6 4 1.5-7.5L2 8h7z"/></svg>{p.premium} premium</span>}
            <span class="text-primary font-semibold inline-flex items-center gap-1">View pack <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
<style>
  .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
</style>
