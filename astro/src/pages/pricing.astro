---
import Layout from "@/layouts/Layout.astro";
const tiers = [
  {
    name: "Free",
    price: "$0",
    period: "forever",
    desc: "Try the prompt library and optimizer.",
    features: [
      "Browse the full prompt library",
      "5 optimisations / month",
      "Save up to 10 favorites",
      "All Asian language landing pages",
    ],
    cta: { label: "Get started", href: "/auth" },
    highlight: false,
  },
  {
    name: "Pro",
    price: "$12",
    period: "/ month",
    desc: "For individual creators and operators.",
    features: [
      "Unlimited optimisations",
      "Unlimited saved prompts",
      "Power Packs included",
      "Multi-platform compare side-by-side",
      "Email support",
    ],
    cta: { label: "Start Pro trial", href: "/auth?plan=pro" },
    highlight: true,
  },
  {
    name: "Team",
    price: "$32",
    period: "/ month / seat",
    desc: "For teams shipping AI work daily.",
    features: [
      "Everything in Pro",
      "Shared prompt libraries",
      "Brand voice presets",
      "Usage analytics & audit log",
      "Priority support",
    ],
    cta: { label: "Talk to sales", href: "/contact?topic=team" },
    highlight: false,
  },
];
---
<Layout title="Pricing — PromptAndGo" description="Simple, transparent pricing. Free tier, Pro for individuals, Team for orgs.">
  <section class="container py-16 md:py-24">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight">Simple, transparent pricing</h1>
      <p class="mt-4 text-lg text-muted-foreground">Pick a tier. Cancel anytime. No surprise charges.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {tiers.map(t => (
        <div class={`rounded-2xl border p-7 flex flex-col ${t.highlight ? 'border-primary/40 shadow-glow ring-1 ring-primary/20 bg-card' : 'border-border/60 bg-card'}`}>
          {t.highlight && <span class="self-start mb-3 inline-block text-xs font-semibold px-2.5 py-1 rounded-full bg-primary text-primary-foreground">Most popular</span>}
          <h2 class="text-2xl font-semibold">{t.name}</h2>
          <div class="mt-3 flex items-baseline gap-1">
            <span class="text-4xl font-bold">{t.price}</span>
            <span class="text-muted-foreground">{t.period}</span>
          </div>
          <p class="mt-2 text-muted-foreground">{t.desc}</p>
          <ul class="mt-6 space-y-2 text-sm">
            {t.features.map(f => (
              <li class="flex items-start gap-2"><span class="text-primary">✓</span><span>{f}</span></li>
            ))}
          </ul>
          <a href={t.cta.href} class={`mt-7 inline-flex items-center justify-center rounded-lg px-5 py-3 font-semibold transition-colors ${t.highlight ? 'bg-primary text-primary-foreground hover:bg-primary/90' : 'border border-border hover:bg-secondary'}`}>
            {t.cta.label}
          </a>
        </div>
      ))}
    </div>
    <div class="mt-12 text-center text-sm text-muted-foreground">Questions? <a href="/contact" class="text-primary hover:underline">Talk to us</a> · See <a href="/enterprise" class="text-primary hover:underline">Enterprise</a></div>
  </section>
</Layout>
