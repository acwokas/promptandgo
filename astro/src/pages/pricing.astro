---
import Layout from "@astro/layouts/Layout.astro";

// TODO 3 rebuild 2026-05-11 — 6-tier structure aligned to the Stripe
// products in supabase/functions/_shared/stripe-prices.ts:
//   per_prompt | per_pack | pro_monthly | pro_annual | team_monthly | team_annual
// Free tier rendered as a callout banner above the grid (not one of
// the 6 paid rows — it's not a Stripe product). Lifetime $349 is
// intentionally absent pending TODO 5 (Adrian's decision: keep hidden /
// promote to a 7th tile / drop entirely).
//
// Display prices below are wired to the locked 2026-05-10 monthly
// pricing ($12 Pro Monthly). Annual prices apply Stripe's 20% annual
// discount convention from the FAQ. Adrian: review copy + feature
// lists per row before launch — the structure + CTAs are correct, but
// the feature bullets are placeholders extrapolated from the prior
// 3-tier version and should be refined.
const tiers = [
  {
    tierKey: "per_prompt",
    name: "Single Prompt",
    price: "$0.99",
    period: "each",
    desc: "Buy individual PRO prompts as you need them.",
    features: [
      "Pay only for what you use",
      "No subscription commitment",
      "Lifetime access to purchased prompts",
      "Side-by-side platform output preview",
    ],
    cta: { label: "Browse PRO prompts", href: "/prompts?filter=pro" },
    purchase: "payment",
    highlight: false,
  },
  {
    tierKey: "per_pack",
    name: "Power Pack",
    price: "$4.99",
    period: "/ pack",
    desc: "Bundled prompt collections — better unit economics than buying singles.",
    features: [
      "Curated multi-prompt bundles",
      "Themed by workflow (research, sales, learning)",
      "Average ~$0.50/prompt vs $0.99 single",
      "Lifetime access",
    ],
    cta: { label: "See packs", href: "/packs" },
    purchase: "payment",
    highlight: false,
  },
  {
    tierKey: "pro_monthly",
    name: "Pro Monthly",
    price: "$12",
    period: "/ month",
    desc: "For individual creators and operators.",
    features: [
      "Unlimited optimisations",
      "Unlimited saved prompts",
      "All Power Packs included",
      "Side-by-side platform compare",
      "Priority email support",
      "API access (beta)",
    ],
    cta: { label: "Start Pro Monthly", href: "/auth?plan=pro_monthly" },
    purchase: "subscription",
    highlight: true,
  },
  {
    tierKey: "pro_annual",
    name: "Pro Annual",
    price: "$115",
    period: "/ year",
    desc: "Same as Pro Monthly, 20% off the annual cost.",
    features: [
      "Everything in Pro Monthly",
      "Save ~$29/year vs monthly",
      "One bill, one tax invoice",
      "Cancel anytime, refund on remainder",
    ],
    cta: { label: "Start Pro Annual", href: "/auth?plan=pro_annual" },
    purchase: "subscription",
    highlight: false,
  },
  {
    tierKey: "team_monthly",
    name: "Team Monthly",
    price: "$32",
    period: "/ month / seat",
    desc: "For teams shipping AI work daily.",
    features: [
      "Everything in Pro Monthly",
      "Shared prompt libraries",
      "Brand voice presets",
      "Usage analytics & audit log",
      "Dedicated support channel",
    ],
    cta: { label: "Start Team Monthly", href: "/auth?plan=team_monthly" },
    purchase: "subscription",
    highlight: false,
  },
  {
    tierKey: "team_annual",
    name: "Team Annual",
    price: "$307",
    period: "/ year / seat",
    desc: "Same as Team Monthly with SSO + 20% off.",
    features: [
      "Everything in Team Monthly",
      "SSO & SCIM included",
      "Save ~$77/seat/year vs monthly",
      "Custom DPA on request",
      "Annual security review",
    ],
    cta: { label: "Talk to sales", href: "/contact?topic=team_annual" },
    purchase: "subscription",
    highlight: false,
  },
];
const faqs = [
  { q: "Is there a free trial for Pro?", a: "Yes — you can cancel anytime during the first 14 days at no charge." },
  { q: "Do you bill annually?", a: "Yes, with a 20% discount on annual plans. Switch from monthly anytime." },
  { q: "What if my team is bigger than 50?", a: "Talk to sales — we have an Enterprise tier with custom pricing, SSO, and a DPA." },
  { q: "Can I cancel anytime?", a: "Yes. Your access continues to the end of the paid period." },
];
---
<Layout title="Pricing — PromptAndGo" description="Simple, transparent pricing. Free tier, Pro for individuals, Team for orgs.">
  <section class="container max-w-7xl py-16 md:py-24">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Pricing</span>
      <h1 class="mt-3 text-4xl md:text-6xl font-extrabold tracking-tight">Simple, transparent <span class="text-gradient-brand">pricing</span>.</h1>
      <p class="mt-5 text-lg text-foreground/70">Pick a tier. Cancel anytime. No surprise charges.</p>
    </div>

    <!-- Free tier callout — not a Stripe product so it doesn't get a card in
         the 6-paid-row grid below, but it's the conversion-funnel entry point. -->
    <div class="max-w-5xl mx-auto mb-8 rounded-2xl border border-border/60 bg-card/60 px-6 py-5 flex flex-col md:flex-row items-start md:items-center gap-4 md:gap-6">
      <div class="flex-1">
        <div class="flex items-baseline gap-2">
          <span class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">Free forever</span>
          <span class="text-lg font-bold">$0</span>
        </div>
        <p class="mt-1 text-sm text-foreground/70">Browse 500+ prompts, run 5 AI optimisations / month, save up to 10 favourites. No credit card.</p>
      </div>
      <a href="/auth?action=signup" class="inline-flex items-center justify-center rounded-xl px-5 h-10 font-semibold border border-border bg-secondary/40 hover:bg-secondary transition-all">Get started free</a>
    </div>

    <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto">
      {tiers.map(t => (
        <div class={`relative rounded-2xl border p-7 md:p-8 flex flex-col card-lift ${t.highlight ? 'border-primary/50 bg-card shadow-brand-lg' : 'border-border/60 bg-card'}`}>
          {t.highlight && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="inline-block text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full bg-gradient-brand text-white shadow-brand">Most popular</span>
            </div>
          )}
          <h2 class="text-xl font-semibold">{t.name}</h2>
          <div class="mt-3 flex items-baseline gap-1.5">
            <span class="text-4xl md:text-5xl font-extrabold tracking-tight">{t.price}</span>
            <span class="text-muted-foreground text-sm">{t.period}</span>
          </div>
          <p class="mt-2 text-sm text-foreground/70">{t.desc}</p>
          <ul class="mt-6 space-y-2.5 text-sm flex-1">
            {t.features.map(f => (
              <li class="flex items-start gap-2.5">
                <svg class="shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: hsl(var(--brand-teal))"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <a href={t.cta.href} class={`mt-7 inline-flex items-center justify-center rounded-xl px-5 h-11 font-semibold transition-all ${t.highlight ? 'bg-gradient-brand text-white shadow-brand hover:shadow-brand-lg' : 'border border-border bg-secondary/40 hover:bg-secondary'}`}>
            {t.cta.label}
          </a>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center text-sm text-muted-foreground">
      Need more? See <a href="/enterprise" class="text-primary hover:underline">Enterprise</a> · <a href="/contact" class="text-primary hover:underline">Talk to us</a>
    </div>

    <!-- FAQ -->
    <div class="mt-20 max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-center">Pricing FAQ</h2>
      <div class="mt-8 divide-y divide-border/60 rounded-2xl border border-border/60 bg-card">
        {faqs.map(f => (
          <details class="group p-5 cursor-pointer">
            <summary class="flex items-center justify-between gap-4 list-none">
              <span class="font-semibold">{f.q}</span>
              <span class="text-muted-foreground transition-transform group-open:rotate-45 text-xl leading-none">+</span>
            </summary>
            <p class="mt-3 text-sm text-foreground/70 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>
