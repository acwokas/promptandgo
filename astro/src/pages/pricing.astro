---
import Layout from "@astro/layouts/Layout.astro";

// TODO 3 + TODO 5 (b) — 8-tier pricing aligned to the Stripe products
// in supabase/functions/_shared/stripe-prices.ts:
//   per_prompt | per_pack | pro_monthly | pro_annual | team_monthly | team_annual | lifetime
// Free is rendered as a callout banner above the grid (not a Stripe
// product). Pro Monthly is the "most popular" highlight. Lifetime is
// the "best value" highlight — distinct visual treatment from the
// subscription cards per Adrian's 2026-05-11 brief.
//
// Adrian's locked 2026-05-11 pricing:
//   per_prompt:   $1.99 each
//   per_pack:     $9.99 / pack
//   pro_monthly:  $12   / month
//   pro_annual:   $120  / year
//   team_monthly: $32   / month (flat, up to 10 seats — NOT per-seat)
//   team_annual:  $320  / year  (flat, up to 10 seats)
//   lifetime:     $349  one-off (all prompts + all packs + future included)
//
// Feature-bullet copy is editorial — refine in-place; structure + CTAs
// match the locked pricing model.
const tiers = [
  {
    tierKey: "per_prompt",
    name: "Per-Prompt Unlock",
    price: "$1.99",
    period: "one-off",
    desc: "Buy a single PRO prompt as you need it.",
    features: [
      "Pay only for what you use",
      "No subscription commitment",
      "Lifetime access to that prompt",
      "Side-by-side platform output preview",
    ],
    cta: { label: "Browse PRO prompts", href: "/prompts?filter=pro" },
    purchase: "payment",
    highlight: false,
  },
  {
    tierKey: "per_pack",
    name: "Per-Pack Unlock",
    price: "$9.99",
    period: "one-off",
    desc: "Bundled prompt collections — better unit economics than buying singles.",
    features: [
      "Curated multi-prompt bundle",
      "Themed by workflow (research, sales, learning)",
      "Roughly half the per-prompt cost",
      "Lifetime access to the bundle",
    ],
    cta: { label: "See packs", href: "/packs" },
    purchase: "payment",
    highlight: false,
  },
  {
    tierKey: "pro_monthly",
    name: "Pro Monthly",
    price: "$12",
    period: "/ month",
    desc: "For individual creators and operators.",
    features: [
      "Unlimited optimisations",
      "Unlimited saved prompts",
      "All Power Packs included",
      "Side-by-side platform compare",
      "Priority email support",
      "API access (beta)",
    ],
    cta: { label: "Start Pro Monthly", href: "/auth?plan=pro_monthly" },
    purchase: "subscription",
    highlight: true,  // "most popular"
  },
  {
    tierKey: "pro_annual",
    name: "Pro Annual",
    price: "$120",
    period: "/ year",
    desc: "Two months free vs Pro Monthly.",
    features: [
      "Everything in Pro Monthly",
      "Save $24/year vs monthly",
      "One bill, one tax invoice",
      "Cancel anytime, refund on remainder",
    ],
    cta: { label: "Start Pro Annual", href: "/auth?plan=pro_annual" },
    purchase: "subscription",
    highlight: false,
  },
  {
    tierKey: "team_monthly",
    name: "Team Monthly",
    price: "$32",
    period: "/ month",
    seats: "up to 10 seats",
    desc: "For small teams shipping AI work daily.",
    features: [
      "Everything in Pro Monthly",
      "Up to 10 seats included (flat)",
      "Shared prompt libraries",
      "Brand voice presets",
      "Usage analytics & audit log",
      "Dedicated support channel",
    ],
    cta: { label: "Start Team Monthly", href: "/auth?plan=team_monthly" },
    purchase: "subscription",
    highlight: false,
  },
  {
    tierKey: "team_annual",
    name: "Team Annual",
    price: "$320",
    period: "/ year",
    seats: "up to 10 seats",
    desc: "Team Monthly, two months free.",
    features: [
      "Everything in Team Monthly",
      "Up to 10 seats included (flat)",
      "Save $64/year vs monthly",
      "Annual invoice + DPA on request",
      "SSO available on request",
    ],
    cta: { label: "Start Team Annual", href: "/auth?plan=team_annual" },
    purchase: "subscription",
    highlight: false,
  },
];

// Lifetime is rendered as its own card OUTSIDE the 6-tier subscription
// grid — visually distinct because it's a one-off purchase with
// future-included scope (semantic difference, not just a 7th column).
const lifetime = {
  tierKey: "lifetime",
  name: "Lifetime",
  price: "$349",
  period: "one-off",
  desc: "All prompts, all packs, and every future addition. Forever.",
  features: [
    "Everything in Pro, forever",
    "All current Power Packs included",
    "All future packs + prompts included",
    "Priority feature requests",
    "One bill, no renewal",
  ],
  cta: { label: "Buy Lifetime", href: "/checkout?type=lifetime" },
};
const faqs = [
  { q: "Is there a free trial for Pro?", a: "Yes — you can cancel anytime during the first 14 days at no charge." },
  { q: "Do you bill annually?", a: "Yes. Pro Annual is $120/year (two months free vs $12 × 12 = $144). Team Annual is $320/year on the same basis. Switch from monthly anytime." },
  { q: "How many seats does Team cover?", a: "Up to 10 seats are included in the flat Team price (Monthly $32, Annual $320). For 11+ seats or SSO/DPA requirements, talk to sales." },
  { q: "What does Lifetime include?", a: "All current PRO prompts, all current Power Packs, and every future prompt or pack added after your purchase. One $349 payment, no renewal." },
  { q: "Can I cancel anytime?", a: "Yes. Your access continues to the end of the paid period. Lifetime is a one-off purchase — no cancellation needed." },
];
---
<Layout title="Pricing — PromptAndGo" description="Simple, transparent pricing. Free tier, Pro for individuals, Team for orgs.">
  <section class="container max-w-7xl py-16 md:py-24">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Pricing</span>
      <h1 class="mt-3 text-4xl md:text-6xl font-extrabold tracking-tight">Simple, transparent <span class="text-gradient-brand">pricing</span>.</h1>
      <p class="mt-5 text-lg text-foreground/70">Pick a tier. Cancel anytime. No surprise charges.</p>
    </div>

    <!-- Free tier callout — not a Stripe product so it doesn't get a card in
         the 6-paid-row grid below, but it's the conversion-funnel entry point. -->
    <div class="max-w-5xl mx-auto mb-8 rounded-2xl border border-border/60 bg-card/60 px-6 py-5 flex flex-col md:flex-row items-start md:items-center gap-4 md:gap-6">
      <div class="flex-1">
        <div class="flex items-baseline gap-2">
          <span class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">Free forever</span>
          <span class="text-lg font-bold">$0</span>
        </div>
        <p class="mt-1 text-sm text-foreground/70">Browse 500+ prompts, run 5 AI optimisations / month, save up to 10 favourites. No credit card.</p>
      </div>
      <a href="/auth?action=signup" class="inline-flex items-center justify-center rounded-xl px-5 h-10 font-semibold border border-border bg-secondary/40 hover:bg-secondary transition-all">Get started free</a>
    </div>

    <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto">
      {tiers.map(t => (
        <div class={`relative rounded-2xl border p-7 md:p-8 flex flex-col card-lift ${t.highlight ? 'border-primary/50 bg-card shadow-brand-lg' : 'border-border/60 bg-card'}`}>
          {t.highlight && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="inline-block text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full bg-gradient-brand text-white shadow-brand">Most popular</span>
            </div>
          )}
          <h2 class="text-xl font-semibold">{t.name}</h2>
          <div class="mt-3 flex items-baseline gap-1.5">
            <span class="text-4xl md:text-5xl font-extrabold tracking-tight">{t.price}</span>
            <span class="text-muted-foreground text-sm">{t.period}</span>
          </div>
          {(t as any).seats && (
            <div class="mt-1 text-xs font-medium text-muted-foreground uppercase tracking-wider">{(t as any).seats}</div>
          )}
          <p class="mt-2 text-sm text-foreground/70">{t.desc}</p>
          <ul class="mt-6 space-y-2.5 text-sm flex-1">
            {t.features.map(f => (
              <li class="flex items-start gap-2.5">
                <svg class="shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: hsl(var(--brand-teal))"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <a href={t.cta.href} class={`mt-7 inline-flex items-center justify-center rounded-xl px-5 h-11 font-semibold transition-all ${t.highlight ? 'bg-gradient-brand text-white shadow-brand hover:shadow-brand-lg' : 'border border-border bg-secondary/40 hover:bg-secondary'}`}>
            {t.cta.label}
          </a>
        </div>
      ))}
    </div>

    <!-- Lifetime card — separate visual band beneath the 6-tier grid. One-off
         purchase with future-included scope (semantic difference, not just a
         7th column). Best-value badge + amber/gradient accent calls it out. -->
    <div class="mt-12 max-w-5xl mx-auto">
      <div class="relative rounded-2xl border-2 border-primary/60 bg-gradient-to-br from-card via-card to-primary/5 p-8 md:p-10 shadow-brand-lg">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
          <span class="inline-block text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full bg-gradient-brand text-white shadow-brand">Best value</span>
        </div>
        <div class="grid md:grid-cols-[1fr_auto] gap-6 md:gap-10 items-center">
          <div>
            <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight">{lifetime.name}</h2>
            <p class="mt-2 text-base text-foreground/80">{lifetime.desc}</p>
            <ul class="mt-5 grid sm:grid-cols-2 gap-x-6 gap-y-2.5 text-sm">
              {lifetime.features.map(f => (
                <li class="flex items-start gap-2.5">
                  <svg class="shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: hsl(var(--brand-teal))"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="flex flex-col items-stretch md:items-end gap-3">
            <div class="flex items-baseline gap-1.5 justify-center md:justify-end">
              <span class="text-5xl md:text-6xl font-extrabold tracking-tight">{lifetime.price}</span>
              <span class="text-muted-foreground text-sm">{lifetime.period}</span>
            </div>
            <a href={lifetime.cta.href} class="inline-flex items-center justify-center rounded-xl px-6 h-12 font-semibold bg-gradient-brand text-white shadow-brand hover:shadow-brand-lg transition-all whitespace-nowrap">
              {lifetime.cta.label}
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-10 text-center text-sm text-muted-foreground">
      Need more? See <a href="/enterprise" class="text-primary hover:underline">Enterprise</a> · <a href="/contact" class="text-primary hover:underline">Talk to us</a>
    </div>

    <!-- FAQ -->
    <div class="mt-20 max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-center">Pricing FAQ</h2>
      <div class="mt-8 divide-y divide-border/60 rounded-2xl border border-border/60 bg-card">
        {faqs.map(f => (
          <details class="group p-5 cursor-pointer">
            <summary class="flex items-center justify-between gap-4 list-none">
              <span class="font-semibold">{f.q}</span>
              <span class="text-muted-foreground transition-transform group-open:rotate-45 text-xl leading-none">+</span>
            </summary>
            <p class="mt-3 text-sm text-foreground/70 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>
