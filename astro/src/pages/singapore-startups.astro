---
import Layout from "@astro/layouts/Layout.astro";
import StaticHero from "@astro/components/StaticHero.astro";
---
<Layout title="AI Prompts for Singapore Startups — PromptAndGo" description="AI prompts tuned for Singapore startups. Pitch decks, investor updates, marketing for the SEA market.">
  <StaticHero eyebrow="For Singapore startups" title="Built for the Lion City." subtitle="Pitch decks, investor updates, hiring copy, and marketing for the SE Asian market." />
  <section class="container max-w-3xl pb-16 prose prose-lg dark:prose-invert max-w-none">
    <h2>Common scenarios</h2>
    <ul>
      <li>Investor updates for monthly board meetings</li>
      <li>Job descriptions for ENTRE/EP candidates</li>
      <li>Multi-market launch copy (SG, MY, ID, VN, TH)</li>
      <li>Singlish-aware customer support</li>
      <li>Government grant applications (EDG, MRA, PSG)</li>
    </ul>
    <p><a href="/library">Browse prompts →</a></p>
  </section>
</Layout>
