---
import Layout from "@astro/layouts/Layout.astro";
import StaticHero from "@astro/components/StaticHero.astro";
const services = [
  { name: "Web app", status: "operational" },
  { name: "Optimiser API", status: "operational" },
  { name: "Library", status: "operational" },
  { name: "Auth & accounts", status: "operational" },
  { name: "Stripe checkout", status: "operational" },
  { name: "Email delivery", status: "operational" },
];
---
<Layout title="Status — PromptAndGo" description="PromptAndGo service status.">
  <StaticHero eyebrow="Status" title="All systems operational." />
  <section class="container max-w-3xl pb-16">
    <div class="rounded-2xl border border-border bg-card divide-y divide-border">
      {services.map(s => (
        <div class="flex items-center justify-between px-5 py-4">
          <span class="font-medium">{s.name}</span>
          <span class="inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 dark:text-emerald-300">
            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
            Operational
          </span>
        </div>
      ))}
    </div>
    <p class="mt-6 text-sm text-foreground/60">Subscribe to incident updates: <a href="/newsletter" class="text-primary hover:underline">newsletter</a>. Report an issue: <a href="/contact?topic=incident" class="text-primary hover:underline">contact</a>.</p>
  </section>
</Layout>
