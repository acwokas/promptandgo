---
import Layout from "@astro/layouts/Layout.astro";
import { sbSelect } from "@astro/lib/supabase-rest";

let articles: any[] = [];
let fetchError: string | null = null;
try {
  articles = await sbSelect("articles", {
    select: "slug,title,synopsis,meta_description,thumbnail_url,published_date,focus_keyword",
    filter: "is_published=eq.true",
    order: "published_date.desc",
  });
} catch (e: any) {
  fetchError = e?.message || "Failed to load articles";
}

function readingTime(text: string | null | undefined) {
  if (!text) return "5 min";
  const words = text.replace(/<[^>]+>/g, " ").split(/\s+/).filter(Boolean).length;
  const mins = Math.max(2, Math.round(words / 220));
  return `${mins} min`;
}
---
<Layout title="AI Tips & Tutorials — PromptAndGo" description="Practical guides to writing better AI prompts across platforms and languages.">
  <section class="relative overflow-hidden">
    <div class="brand-orb w-[400px] h-[400px] -top-20 -left-20" style="background: hsl(var(--brand-indigo));"></div>
    <div class="relative container max-w-6xl pt-16 md:pt-24 pb-10">
      <div class="max-w-2xl">
        <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Guides &amp; Tutorials</span>
        <h1 class="mt-3 text-4xl md:text-6xl font-extrabold tracking-tight">Get better at <span class="text-gradient-brand">prompting</span>.</h1>
        <p class="mt-5 text-lg text-foreground/70">Practical pieces on writing better prompts. Read in 5–10 minutes each.</p>
      </div>
    </div>
  </section>

  <section class="container max-w-6xl pb-20">
    {fetchError && (
      <div class="rounded-2xl border border-destructive/40 bg-destructive/5 text-destructive p-5 text-sm">
        Couldn't load articles: {fetchError}
      </div>
    )}
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {articles.map(a => (
        <a href={`/tips/${a.slug}`} class="group card-lift rounded-2xl border border-border/60 bg-card overflow-hidden flex flex-col">
          {a.thumbnail_url && (
            <div class="aspect-[16/9] overflow-hidden bg-secondary/40">
              <img src={a.thumbnail_url} alt={a.title} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
            </div>
          )}
          <div class="p-6 flex flex-col flex-1">
            <div class="flex items-center gap-2 text-xs text-muted-foreground mb-3">
              <span class="font-semibold uppercase tracking-wider">Tip</span>
              <span>·</span>
              <span>{readingTime(a.synopsis ?? a.meta_description ?? "")}</span>
            </div>
            <h2 class="text-lg font-bold tracking-tight leading-snug">{a.title}</h2>
            <p class="mt-2.5 text-sm text-foreground/70 leading-relaxed flex-1 line-clamp-3">{a.synopsis ?? a.meta_description ?? ""}</p>
            <div class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-primary">
              Read
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
</style>
