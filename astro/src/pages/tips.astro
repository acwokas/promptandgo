---
import Layout from "@astro/layouts/Layout.astro";
const articles = [
  { slug: "how-to-write-ai-prompts", title: "How to write AI prompts that actually work", excerpt: "Anatomy of a high-quality prompt — context, role, constraints, examples.", read: "5 min" },
  { slug: "best-ai-prompts-for-small-business-2025", title: "Best AI prompts for small business in 2026", excerpt: "Marketing, ops, customer support — copy-paste ready.", read: "7 min" },
  { slug: "ai-prompts-that-save-you-hours", title: "AI prompts that save you hours every week", excerpt: "10 templates that compress recurring work.", read: "6 min" },
  { slug: "ai-prompts-for-marketing-campaigns", title: "AI prompts for marketing campaigns", excerpt: "Briefs, hooks, ad copy, social — at scale.", read: "8 min" },
  { slug: "ai-prompts-for-customer-support", title: "AI prompts for customer support", excerpt: "Empathetic, accurate, on-brand responses.", read: "5 min" },
  { slug: "ai-prompts-for-social-media-content", title: "AI prompts for social media content", excerpt: "Platform-specific best practices that don't sound like a bot.", read: "6 min" },
  { slug: "ai-prompts-for-content-writers", title: "AI prompts for content writers", excerpt: "From outline to final draft, across formats.", read: "9 min" },
  { slug: "ai-prompts-for-business-strategy", title: "AI prompts for business strategy", excerpt: "Decision frameworks, market analysis, positioning.", read: "8 min" },
  { slug: "beginners-guide-midjourney-prompts", title: "Beginner's guide to Midjourney prompts", excerpt: "Style, composition, parameters, iteration.", read: "10 min" },
  { slug: "ai-prompts-in-asian-languages", title: "AI prompts in Asian languages", excerpt: "When to write the prompt in the target language vs translate.", read: "7 min" },
  { slug: "multi-platform-prompting-guide", title: "Multi-platform prompting guide", excerpt: "Same idea, optimised for ChatGPT, Claude, Gemini, Mistral, Grok.", read: "9 min" },
];
---
<Layout title="AI Tips & Tutorials — PromptAndGo" description="Practical guides to writing better AI prompts across platforms and languages.">
  <section class="relative overflow-hidden">
    <div class="brand-orb w-[400px] h-[400px] -top-20 -left-20" style="background: hsl(var(--brand-indigo));"></div>
    <div class="relative container max-w-6xl pt-16 md:pt-24 pb-10">
      <div class="max-w-2xl">
        <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Guides &amp; Tutorials</span>
        <h1 class="mt-3 text-4xl md:text-6xl font-extrabold tracking-tight">Get better at <span class="text-gradient-brand">prompting</span>.</h1>
        <p class="mt-5 text-lg text-foreground/70">Practical pieces on writing better prompts. Read in 5–10 minutes each.</p>
      </div>
    </div>
  </section>

  <section class="container max-w-6xl pb-20">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {articles.map(a => (
        <a href={`/tips/${a.slug}`} class="group card-lift rounded-2xl border border-border/60 bg-card p-6 flex flex-col">
          <div class="flex items-center gap-2 text-xs text-muted-foreground mb-3">
            <span class="font-semibold uppercase tracking-wider">Tip</span>
            <span>·</span>
            <span>{a.read}</span>
          </div>
          <h2 class="text-lg font-bold tracking-tight leading-snug">{a.title}</h2>
          <p class="mt-2.5 text-sm text-foreground/70 leading-relaxed flex-1">{a.excerpt}</p>
          <div class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-primary">
            Read
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
